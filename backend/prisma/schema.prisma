generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model users {
  id       Int    @id @default(autoincrement())
  NAME     String @db.VarChar(100)
  email    String @unique(map: "email") @db.VarChar(150)
  PASSWORD String @db.VarChar(255)
} 
